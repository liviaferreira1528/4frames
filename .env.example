# 4Frames - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# MySQL (Railway provê essas vars automaticamente)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha
MYSQL_DATABASE=4frames
MYSQL_PORT=3306

# JWT
JWT_SECRET=4frames_secret_key_troque_isso

# Porta (Railway define PORT automaticamente)
PORT=3000
